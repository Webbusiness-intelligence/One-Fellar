# Genalot — Seedance via Ark (BytePlus ModelArk / Volcengine) direct.
# Set these as ENVIRONMENT VARIABLES on the WORKER (Render), and optionally on Vercel.
# Do NOT commit real values. Replace every <...> placeholder, then remove the angle brackets.
#
# Where to get the model ids: Ark console -> Seedance 2.0 model -> "API call guide".
# BytePlus international base (SA-usable): https://ark.ap-southeast.bytepluses.com
# Volcengine China base (needs +86 phone + Chinese ID): https://ark.cn-beijing.volces.com

ARK_API_KEY=<your NEW rotated key>
USE_ARK_SEEDANCE=1
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com
ARK_SEEDANCE_MODEL=<model id from your console's "API call guide">
ARK_SEEDANCE_FAST_MODEL=<fast variant id>
